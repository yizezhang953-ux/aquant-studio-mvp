      "allow_odd_lot_sell": true,
      "t_plus_one": true,
      "price_controls": {
        "daily_price_limit_required": true,
        "require_limit_fields": false
      },
      "fee_model": {
        "commission_rate": 0.0003,
        "min_commission": 5.0,
        "transfer_fee_rate": 0.00001,
        "stamp_duty_sell_rate": 0.0005
      }
    },
    "hk_stock": {
      "name": "Hong Kong stock",
      "currency": "HKD",
      "symbol_pattern": "^[0-9]{5}\\.HK$",
      "allowed_order_types": ["limit", "enhanced_limit", "special_limit", "at_auction", "at_auction_limit"],
      "default_board_lot": 100,
      "board_lots": {
        "00700.HK": 100,
        "00005.HK": 400,
        "09988.HK": 100
      },
      "max_board_lots_per_order": 3000,
      "price_controls": {
        "require_limit_fields": false
      },
      "fee_model": {
        "brokerage_rate": 0.0003,
        "sfc_transaction_levy_rate": 0.000027,
        "afrc_transaction_levy_rate": 0.0000015,
        "trading_fee_rate": 0.0000565,
        "stamp_duty_rate": 0.001,
        "transfer_deed_stamp_duty": 5.0
      }
    }
  }
